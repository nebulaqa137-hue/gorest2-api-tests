<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="GoRest API Test Suite" verbose="1" thread-count="1">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- ===== AUTH TESTS ===== -->
    <test name="Auth Tests">
        <classes>
            <class name="com.api.tests.auth.AuthTests"/>
        </classes>
    </test>

    <!-- ===== USER CRUD TESTS ===== -->
    <test name="User CRUD Tests">
        <classes>
            <class name="com.api.tests.users.UserCrudTests"/>
        </classes>
    </test>

    <!-- ===== SCHEMA VALIDATION TESTS ===== -->
    <test name="Schema Validation Tests">
        <classes>
            <class name="com.api.tests.schema.SchemaValidationTests"/>
        </classes>
    </test>

    <!-- ===== NEGATIVE TESTS ===== -->
    <test name="Negative Tests">
        <classes>
            <class name="com.api.tests.users.NegativeUserTests"/>
        </classes>
    </test>

    <!-- ===== INTEGRATION TESTS (ejecutar de último) ===== -->
    <test name="Integration Tests">
        <classes>
            <class name="com.api.tests.integration.UserIntegrationTests"/>
        </classes>
    </test>

</suite>
